@using static TaskManager.Models.ViewModels.UserViewModels
@model LoginModel
@{
    ViewBag.Title = "Login";
}

@* <h2 class="welcome-title">Log In</h2> *@

<div class="text-danger" asp-validation-summary="ModelOnly"></div> @*ModelOnly => only model-level errors are specified*@

<h1 class="welcome-title">Welcome back</h1>

<form asp-action="Login" class="form" method="post">

    <div class="mb-3">
        <label asp-for="Email" class="form-label">Email</label>
        <input asp-for="Email" class="form-control" type="email" name="Email" id="Email" />
        <div>
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="Password" class="form-label">Password</label>
        <input asp-for="Password" class="form-control" type="password" name="Password" id="Password" />
        <div>
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>
    </div>

    <div class="mb-3">
        <button type="submit" class="lp-btn btn">Log in</button>
    </div>

</form>

<p class="signup-prompt">
    Don't have an account?
    <a href="signup.html" class="signup-link">Sign up</a>
</p>
